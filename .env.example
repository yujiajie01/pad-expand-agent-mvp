PORT=8787

# WebSocket 握手密钥（必填，自行改为足够长的随机串）
WS_KEY=

# LLM（可选；未配置 OPENAI_API_KEY 时会回退到规则解析）
# 国内高性价比（OpenAI 兼容）：填对应平台的 Key，并设置下方 OPENAI_BASE_URL + OPENAI_MODEL
OPENAI_API_KEY=
#
# 方案 1 — DeepSeek（价格低、能力强，推荐优先试）
# OPENAI_BASE_URL=https://api.deepseek.com
# OPENAI_MODEL=deepseek-chat
#
# 方案 2 — 通义千问 Qwen（阿里云 DashScope 兼容模式，生态成熟）
# OPENAI_BASE_URL=https://dashscope.aliyuncs.com/compatible-mode/v1
# OPENAI_MODEL=qwen-turbo
#
# 方案 3 — 智谱 GLM-4-Flash（智谱「Flash」档位，便宜、延迟低）
# OPENAI_BASE_URL=https://open.bigmodel.cn/api/paas/v4/
# OPENAI_MODEL=glm-4-flash
#
# 若仍用 OpenAI 官方：不要设置 OPENAI_BASE_URL，并把 OPENAI_MODEL 改为如 gpt-4o-mini
OPENAI_BASE_URL=https://api.deepseek.com
OPENAI_MODEL=deepseek-chat

# LangSmith（可选）
LANGSMITH_API_KEY=
LANGSMITH_TRACING=false
LANGCHAIN_TRACING_V2=false
LANGCHAIN_PROJECT=pad-expand-agent-mvp

# Langfuse（可选；docker compose 启动后访问 http://localhost:3000 创建项目获取 Key）
LANGFUSE_PUBLIC_KEY=
LANGFUSE_SECRET_KEY=
LANGFUSE_HOST=http://localhost:3000

# Temporal（可选；USE_TEMPORAL_WORKER=true 时 /chat/turn 经 Temporal 调度）
TEMPORAL_ADDRESS=localhost:7233
TEMPORAL_NAMESPACE=default
USE_TEMPORAL_WORKER=false

# LiteLLM Proxy（可选；启动后将 OPENAI_BASE_URL 改为下方地址）
# OPENAI_BASE_URL=http://localhost:4000/v1
